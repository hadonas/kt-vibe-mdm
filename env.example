# ===========================================
# MDM Backend 환경변수 설정
# ===========================================
# 이 파일을 .env로 복사하고 실제 값으로 수정하세요.
# cp env.example .env

# ===========================================
# 서버 설정
# ===========================================
# 서버 포트 (내부 포트는 8080 고정, 외부 포트만 변경 가능)
SERVER_PORT=8080

# Spring 프로파일 (dev, prod, test)
SPRING_PROFILES_ACTIVE=dev

# ===========================================
# MongoDB 설정
# ===========================================
# MongoDB Root 사용자 (Docker Compose용)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password

# MongoDB 연결 정보
MONGO_DB=mdm
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=password
MONGO_AUTH_DB=admin

# MongoDB 연결 URI (컨테이너 간 통신용)
MONGO_URI=mongodb://admin:password@mongodb:27017/mdm?authSource=admin

# ===========================================
# JWT 인증 설정
# ===========================================
# JWT 토큰 서명에 사용할 비밀키 (보안상 반드시 변경하세요!)
JWT_SECRET=change-this-to-a-strong-random-secret-key-for-production-use-min-32-chars

# JWT 토큰 발급자
JWT_ISSUER=mdm.local

# JWT 토큰 만료 시간 (밀리초, 24시간 = 86400000)
JWT_EXPIRATION=86400000

# ===========================================
# 기본 관리자 계정
# ===========================================
# 첫 실행 시 생성되는 관리자 계정 (보안상 반드시 변경하세요!)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=admin123

# ===========================================
# AI/ML 서비스 설정
# ===========================================
# LLM API 설정 (OpenAI 또는 로컬 Ollama)
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4

# 임베딩 API 설정
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI API 키 (실제 키로 변경하세요)
AI_API_KEY=your-openai-api-key-here

# ===========================================
# Vector Search 설정
# ===========================================
# MongoDB Atlas Vector Search 인덱스 이름
ATLAS_VECTOR_INDEX_PURPOSE=purpose_idx

# 유사도 검색 임계값 (0.0 ~ 1.0)
SIM_THRESHOLD=0.82

# 기본 검색 결과 개수
TOPK_DEFAULT=5

# 벡터 샤딩 설정
VECTOR_SHARD_COUNT=4
# 초기 검색 시 기준 샤드 좌우로 확장할 범위 (fanout=1 -> 기준샤드 ±1 포함)
VECTOR_SEARCH_FANOUT=1
# 1차 검색 결과가 (요청 size * 이 비율) 미만이면 전체 샤드로 확장
VECTOR_SEARCH_MIN_SUFFICIENT_RATIO=0.5

# ===========================================
# 파일 처리 설정
# ===========================================
# 임시 파일 디렉토리
TMP_DIR=/tmp/mdm

# 제외할 파일 패턴 (쉼표로 구분)
EXCLUDE_GLOBS=node_modules/**,dist/**,build/**,*.bin,*.zip,*.jar,.git/**

# 최대 아카이브 크기 (MB)
MAX_ARCHIVE_SIZE_MB=50

# 파일 저장 방식 (gridfs, local, s3)
FILE_STORAGE_TYPE=gridfs

# ===========================================
# 이메일 설정 (비밀번호 재설정용)
# ===========================================
# SMTP 서버 설정
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@company.com

# ===========================================
# 로깅 설정
# ===========================================
# 로그 레벨 (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# ===========================================
# 프론트엔드 연결 설정
# ===========================================
# 프론트엔드에서 사용할 API URL
# Docker 환경: 호스트에서 접근하는 URL
# 로컬 개발: 직접 백엔드 주소
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# ===========================================
# 개발/테스트용 설정
# ===========================================
# 로컬 개발 시 사용할 설정들
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
# LLM_API_BASE=http://localhost:11434  # 로컬 Ollama
# EMBEDDING_API_BASE=http://localhost:11434

# ===========================================
# 프로덕션용 설정 예시
# ===========================================
# 프로덕션 환경에서는 다음 값들을 반드시 변경하세요:
# JWT_SECRET=your-super-secure-random-secret-key-here
# ADMIN_PASSWORD=your-secure-admin-password
# MONGO_PASSWORD=your-secure-mongo-password
# AI_API_KEY=your-production-openai-api-key
# MAIL_USERNAME=your-production-email@company.com
# MAIL_PASSWORD=your-production-email-password

# ===========================================
# 의미론적 청크 설정
# ===========================================
# 의미론적 청크 기능 활성화 여부
SEMANTIC_CHUNK_ENABLED=true

# 애플리케이션 시작 시 데이터 마이그레이션 수행 여부
SEMANTIC_CHUNK_MIGRATE_ON_START=false