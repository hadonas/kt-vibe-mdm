# ===========================================
# MDM Frontend2 환경변수 설정
# ===========================================
# 이 파일을 .env.local로 복사하고 실제 값으로 수정하세요.
# cp env.example .env.local

# ===========================================
# API 연결 설정
# ===========================================
# 백엔드 API 기본 URL
# 
# Docker Compose 환경:
# - 브라우저에서 접근: http://localhost:8080/api
# 
# 로컬 개발 환경:
# - 백엔드 직접 실행: http://localhost:8080/api
# - 백엔드 Docker만 실행: http://localhost:8080/api
#
# 프로덕션 환경:
# - 실제 도메인: https://api.yourdomain.com/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# ===========================================
# 개발 환경별 설정 예시
# ===========================================

# 1. Docker Compose로 전체 실행 시:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# 2. 로컬에서 프론트엔드만 개발 시 (백엔드는 Docker):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# 3. 완전 로컬 개발 환경:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# 4. 프로덕션 환경:
# NEXT_PUBLIC_API_BASE_URL=https://your-backend-domain.com/api

# ===========================================
# Next.js 환경 설정
# ===========================================
# 개발/프로덕션 환경 구분
NODE_ENV=development

# ===========================================
# 네트워크 디버깅 정보
# ===========================================
# 연결 문제 해결을 위한 참고 정보:
#
# 1. Docker Compose 환경에서 컨테이너 간 통신:
#    - 프론트엔드 컨테이너 → 백엔드 컨테이너: http://mdm-backend:8080/api
#    - 하지만 브라우저는 호스트에서 실행되므로: http://localhost:8080/api
#
# 2. 포트 매핑:
#    - 백엔드: 호스트 8080 → 컨테이너 8080
#    - 프론트엔드: 호스트 3000 → 컨테이너 80
#
# 3. 네트워크 확인 명령어:
#    - docker-compose ps (컨테이너 상태 확인)
#    - docker network ls (네트워크 목록)
#    - docker network inspect mdm_mdm-network (네트워크 상세 정보)
#    - curl http://localhost:8080/api/actuator/health (백엔드 헬스체크)
#    - curl http://localhost:3000/health (프론트엔드 헬스체크)

# ===========================================
# 트러블슈팅 가이드
# ===========================================
# 
# 문제: 프론트엔드에서 백엔드 API 호출 실패
# 
# 해결 방법:
# 1. 백엔드 컨테이너가 정상 실행 중인지 확인:
#    docker-compose ps
#    docker-compose logs backend
#
# 2. 백엔드 헬스체크 확인:
#    curl http://localhost:8080/api/actuator/health
#
# 3. 네트워크 연결 확인:
#    docker-compose exec frontend2 ping mdm-backend
#
# 4. CORS 설정 확인:
#    백엔드에서 프론트엔드 도메인이 허용되어 있는지 확인
#
# 5. 환경 변수 확인:
#    docker-compose config (환경 변수 치환 결과 확인)
#
# 6. 브라우저 개발자 도구에서 네트워크 탭 확인:
#    - API 호출 URL이 올바른지 확인
#    - CORS 에러가 있는지 확인
#    - 401/403 인증 에러가 있는지 확인

# ===========================================
# 백엔드 벡터 샤딩 환경변수 참고 (읽기 전용)
# ===========================================
# 아래 변수들은 백엔드에서만 사용되며 프론트엔드 빌드에는 포함되지 않습니다.
# VECTOR_SHARD_COUNT
# VECTOR_SEARCH_FANOUT
# VECTOR_SEARCH_MIN_SUFFICIENT_RATIO
